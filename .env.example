# ==================================================
# TRAMARSA ERP - Variables de entorno (EJEMPLO)
# Copiar como .env.local o .env.production
# ==================================================

# APP
NODE_ENV=development
PORT=3000

# BASE DE DATOS
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tramarsa_db
DB_USER=tramarsa_user
DB_PASSWORD=tramarsa_pass

# JWT
JWT_SECRET=cambiar_por_clave_segura
JWT_EXPIRES_IN=8h

# CORS - URL del frontend
CORS_ORIGIN=http://localhost:4200

# SIMULACION SUNAT (mock)
SUNAT_MOCK=true
SUNAT_API_URL=https://api.sunat.gob.pe

# SIMULACION BANCO DE LA NACION (mock)
BANCO_MOCK=true
BANCO_API_URL=https://api.bn.gob.pe
